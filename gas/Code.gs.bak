/**
 * ═══════════════════════════════════════════════════════════════
 *  Wish List — Google Apps Script Backend  (gas/Code.gs)
 * ═══════════════════════════════════════════════════════════════
 *
 *  SETUP STEPS
 *  ───────────
 *  1. Create a new Google Sheet with a tab named "Items".
 *     Columns (row 1 = headers):
 *       A: id | B: title | C: description | D: imageUrl | E: link
 *       F: price | G: currency | H: tags (comma-separated)
 *       I: purchased | J: createdAt | K: updatedAt
 *
 *  2. Open Extensions → Apps Script. Paste this file as Code.gs.
 *
 *  3. Set Script Properties (Project Settings → Script Properties):
 *       SPREADSHEET_ID  → the ID from your Sheet URL
 *       SHEET_NAME      → Items  (or whatever you named the tab)
 *       VIEW_TOKEN      → some random secret string
 *       EDIT_TOKEN      → a different random secret string
 *
 *  4. Deploy → New deployment → Web app
 *       Execute as: Me
 *       Who has access: Anyone
 *     Copy the Web App URL into src/config.ts → gasUrl
 *
 *  5. Copy VIEW_TOKEN and EDIT_TOKEN into src/config.ts as well.
 *
 *  6. Run `npm run build`, then paste the contents of dist/index.html
 *     into a new file in Apps Script called "index" (no extension).
 *     You can then serve it from doGet() below.
 * ═══════════════════════════════════════════════════════════════
 */

// ── Config helpers ────────────────────────────────────────────────────────────

function getProp(key) {
  return PropertiesService.getScriptProperties().getProperty(key) || '';
}

function getSheet() {
  const id   = getProp('SPREADSHEET_ID');
  const name = getProp('SHEET_NAME') || 'Items';
  const ss   = SpreadsheetApp.openById(id);
  return ss.getSheetByName(name);
}

// ── Column mapping ────────────────────────────────────────────────────────────

const COL = {
  id:          1,
  title:       2,
  description: 3,
  imageUrl:    4,
  link:        5,
  price:       6,
  currency:    7,
  tags:        8,
  purchased:   9,
  createdAt:   10,
  updatedAt:   11,
  TOTAL:       11,
};

// ── Row → object ──────────────────────────────────────────────────────────────

function rowToItem(row) {
  return {
    id:          String(row[COL.id - 1]          || ''),
    title:       String(row[COL.title - 1]       || ''),
    description: String(row[COL.description - 1] || ''),
    imageUrl:    String(row[COL.imageUrl - 1]     || ''),
    link:        String(row[COL.link - 1]         || ''),
    price:       row[COL.price - 1] !== '' && row[COL.price - 1] !== null
                   ? Number(row[COL.price - 1])
                   : undefined,
    currency:    String(row[COL.currency - 1]    || 'USD'),
    tags:        String(row[COL.tags - 1]         || '')
                   .split(',')
                   .map(t => t.trim())
                   .filter(Boolean),
    purchased:   String(row[COL.purchased - 1])  === 'TRUE',
    createdAt:   String(row[COL.createdAt - 1]   || ''),
    updatedAt:   String(row[COL.updatedAt - 1]   || ''),
  };
}

// ── Object → row array ────────────────────────────────────────────────────────

function itemToRow(item) {
  return [
    item.id,
    item.title,
    item.description || '',
    item.imageUrl    || '',
    item.link        || '',
    item.price !== undefined ? item.price : '',
    item.currency    || 'USD',
    (item.tags || []).join(', '),
    item.purchased ? 'TRUE' : 'FALSE',
    item.createdAt   || new Date().toISOString(),
    item.updatedAt   || new Date().toISOString(),
  ];
}

// ── doGet — serves the Svelte app HTML ───────────────────────────────────────

function doGet(e) {
  try {
    const html = HtmlService.createHtmlOutputFromFile('index')
      .setTitle('Wish List')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
      .setSandboxMode(HtmlService.SandboxMode.IFRAME);
    return html;
  } catch (err) {
    return HtmlService.createHtmlOutput(
      '<p style="font-family:sans-serif;padding:2rem">App not deployed yet. See README.</p>'
    );
  }
}

// ── GAS server functions (called via google.script.run) ───────────────────────

/**
 * Returns all non-purchased items.
 */
function getItems() {
  const sheet = getSheet();
  if (!sheet) return [];

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return [];

  const data = sheet.getRange(2, 1, lastRow - 1, COL.TOTAL).getValues();
  return data
    .map(rowToItem)
    .filter(item => item.id && !item.purchased);
}

/**
 * Upsert an item. Creates a new row if id not found, updates existing row otherwise.
 */
function saveItem(item) {
  const sheet = getSheet();
  if (!sheet) throw new Error('Sheet not found');

  const lastRow = sheet.getLastRow();

  // Look for existing row by id
  if (lastRow >= 2) {
    const ids = sheet.getRange(2, COL.id, lastRow - 1, 1).getValues().flat();
    const rowIndex = ids.indexOf(item.id);
    if (rowIndex >= 0) {
      // Update existing row
      const sheetRow = rowIndex + 2; // +2 because 1-indexed + header row
      sheet.getRange(sheetRow, 1, 1, COL.TOTAL).setValues([itemToRow(item)]);
      return item;
    }
  }

  // Append new row
  sheet.appendRow(itemToRow(item));
  return item;
}

/**
 * Delete an item row by id.
 */
function deleteItem(id) {
  const sheet = getSheet();
  if (!sheet) throw new Error('Sheet not found');

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return;

  const ids = sheet.getRange(2, COL.id, lastRow - 1, 1).getValues().flat();
  const rowIndex = ids.indexOf(id);
  if (rowIndex < 0) return; // not found, no-op

  sheet.deleteRow(rowIndex + 2);
}

/**
 * Mark an item as purchased (sets purchased=TRUE, keeps row for records).
 * The front-end removes the item from the active list immediately.
 */
function markPurchased(id) {
  const sheet = getSheet();
  if (!sheet) throw new Error('Sheet not found');

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return;

  const ids = sheet.getRange(2, COL.id, lastRow - 1, 1).getValues().flat();
  const rowIndex = ids.indexOf(id);
  if (rowIndex < 0) return;

  const sheetRow = rowIndex + 2;
  sheet.getRange(sheetRow, COL.purchased).setValue('TRUE');
  sheet.getRange(sheetRow, COL.updatedAt).setValue(new Date().toISOString());
}
