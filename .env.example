# Google Apps Script Web App URL (set after GAS deployment)
VITE_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Auth tokens — set these to any secret strings you choose
VITE_VIEW_TOKEN=your-view-token-here
VITE_EDIT_TOKEN=your-edit-token-here

# App branding (optional)
VITE_APP_NAME=My Wish List
VITE_APP_SUBTITLE=A curated collection of things I love
